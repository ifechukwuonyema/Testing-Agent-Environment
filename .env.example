# ─── Backend endpoints ────────────────────────────────────────────────────────
# Port 8080: Bank, Affiliate, Customer, Transactions, Batch, Notifications, Admin
# Auth is NOT enforced on port 8080 (platform-wide defect D-BATCH-AUTH-1).
KARDIT_BASE_URL=http://167.172.49.177:8080

# Port 8082: Cards (auth-enforced — Bearer + ECDSA signing required)
KARDIT_CARDS_URL=http://167.172.49.177:8082

# ─── Cards auth (port 8082 only) ─────────────────────────────────────────────
# Working defaults are already embedded in cards_e2e_runner.py.
# Override here only if you are testing against a different Cards backend.
CARDS_IAM_URL=https://hasham.platform.dev.chamsswitch.com/gateway/token
CARDS_CLIENT_ID=platform-kardit-card-api
CARDS_CLIENT_SECRET=723aa789be33d3195416aa86e04dabff4d936dea4af0c0ea83788b8db2cadc07
BANK_CLIENT_ID=platform-kardit-bank-api
BANK_CLIENT_SECRET=ca72de6da4ab7574f95f5484f3363fd2f2a6eaec42160ddcae096fe6275d2667

# ─── Canonical entity IDs ────────────────────────────────────────────────────
# These entities are pre-seeded in the shared backend.
# Override only if running against a fresh backend instance — use seed.py to mint them.
CANONICAL_BANK_ID=000045f9-d01b-479c-a84d-0fe82454d55a
CANONICAL_AFFILIATE_ID=a7d5929b-cba8-4e97-8985-2ce1d9fc91c3
CANONICAL_TENANT_ID=00000000-0000-0000-0000-000000000000

# ─── Chain orchestrator ───────────────────────────────────────────────────────
# Optional: path to an Obsidian vault for per-service memory files after each chain run.
# Leave unset if you don't use Obsidian — the chain runs fine without it.
# KARDIT_VAULT=/path/to/your/obsidian/vault

# ─── Runner behaviour ─────────────────────────────────────────────────────────
# Set to 1 to skip happy-path TCs when pre-flight seed fails (saves time on dead envs)
SKIP_ON_PREFLIGHT_FAIL=0
