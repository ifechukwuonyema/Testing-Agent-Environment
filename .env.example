# ─── HOW TO USE ──────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env   (or copy .env.example .env on Windows)
# 2. Fill in the values marked <...>
# 3. .env is git-ignored — never commit it
# Contact the project owner for the credential values.

# ─── Backend endpoints ────────────────────────────────────────────────────────
# Port 8080: Bank, Affiliate, Customer, Transactions, Batch, Notifications, Admin
KARDIT_BASE_URL=http://167.172.49.177:8080

# Port 8082: Cards (auth-enforced — Bearer + ECDSA signing required)
KARDIT_CARDS_URL=http://167.172.49.177:8082

# ─── Cards IAM — non-secret config ───────────────────────────────────────────
CARDS_IAM_URL=https://hasham.platform.dev.chamsswitch.com/gateway/token
CARDS_CLIENT_ID=platform-kardit-card-api
BANK_CLIENT_ID=platform-kardit-bank-api

# ─── Cards IAM — secrets (required to run cards runners) ─────────────────────
CARDS_CLIENT_SECRET=<your-cards-client-secret>
BANK_CLIENT_SECRET=<your-bank-client-secret>

# EC P-256 private key for ECDSA request signing.
# Store the PEM on one line with \n between each line:
# CARDS_SIGNING_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----"
CARDS_SIGNING_KEY_PEM="<your-signing-key-pem-with-\\n-between-lines>"

# ─── Canonical entity IDs ────────────────────────────────────────────────────
# Pre-seeded in the shared backend. Run `python seed.py` to verify.
# Override only when running against a fresh backend — use `python seed.py --mint`.
CANONICAL_BANK_ID=000045f9-d01b-479c-a84d-0fe82454d55a
CANONICAL_AFFILIATE_ID=a7d5929b-cba8-4e97-8985-2ce1d9fc91c3
CANONICAL_TENANT_ID=00000000-0000-0000-0000-000000000000

# ─── Chain orchestrator ───────────────────────────────────────────────────────
# Optional: path to an Obsidian vault for per-service memory files.
# Leave commented out if you don't use Obsidian.
# KARDIT_VAULT=/path/to/your/obsidian/vault

# ─── Runner behaviour ─────────────────────────────────────────────────────────
# Set to 1 to skip happy-path TCs when pre-flight seed fails (saves time on dead envs)
SKIP_ON_PREFLIGHT_FAIL=0
